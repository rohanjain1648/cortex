GEMINI_API_KEY=your_gemini_api_key_here

# Model — gemini-2.5-flash (default, stable GA, free tier) or gemini-2.0-flash
# GEMINI_MODEL=gemini-2.5-flash

# Embedding config (defaults to local sentence-transformers, free, no API key needed)
# EMBEDDING_MODEL=all-MiniLM-L6-v2
# EMBED_BATCH_SIZE=32

# Vector store
# CHROMA_PERSIST_DIR=./chroma_db

# RAG retrieval
# TOP_K=6
